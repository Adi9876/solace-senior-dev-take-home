{
  "name": "solace-decrypt-service",
  "version": "1.0.0",
  "description": "Enclave-style decryption service using AWS Lambda + KMS",
  "main": "index.js",
  "scripts": {
    "build": "npm install --production",
    "deploy": "aws lambda update-function-code --function-name solace-decrypt-service --zip-file fileb://function.zip",
    "package": "zip -r function.zip . -x '*.git*' 'node_modules/.cache/*' 'test/*'",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/client-kms": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "aws",
    "lambda",
    "kms",
    "encryption",
    "security"
  ],
  "author": "Solace Team",
  "license": "MIT"
}
